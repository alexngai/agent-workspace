{
  "name": "agent-workspace",
  "version": "0.1.5",
  "description": "Filesystem workspace management for agents — directory structure, typed I/O, and validation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./protocol": {
      "import": {
        "types": "./dist/protocol/index.d.ts",
        "default": "./dist/protocol/index.js"
      },
      "require": {
        "types": "./dist/protocol/index.d.cts",
        "default": "./dist/protocol/index.cjs"
      }
    },
    "./protocol/task": {
      "import": {
        "types": "./dist/protocol/task.d.ts",
        "default": "./dist/protocol/task.js"
      },
      "require": {
        "types": "./dist/protocol/task.d.cts",
        "default": "./dist/protocol/task.cjs"
      }
    },
    "./protocol/resource-events": {
      "import": {
        "types": "./dist/protocol/resource-events.d.ts",
        "default": "./dist/protocol/resource-events.js"
      },
      "require": {
        "types": "./dist/protocol/resource-events.d.cts",
        "default": "./dist/protocol/resource-events.cjs"
      }
    },
    "./protocol/repo": {
      "import": {
        "types": "./dist/protocol/repo.d.ts",
        "default": "./dist/protocol/repo.js"
      },
      "require": {
        "types": "./dist/protocol/repo.d.cts",
        "default": "./dist/protocol/repo.cjs"
      }
    },
    "./kinds/repo": {
      "import": {
        "types": "./dist/kinds/repo/index.d.ts",
        "default": "./dist/kinds/repo/index.js"
      },
      "require": {
        "types": "./dist/kinds/repo/index.d.cts",
        "default": "./dist/kinds/repo/index.cjs"
      }
    },
    "./kinds/repo/testing": {
      "import": {
        "types": "./dist/kinds/repo/testing.d.ts",
        "default": "./dist/kinds/repo/testing.js"
      },
      "require": {
        "types": "./dist/kinds/repo/testing.d.cts",
        "default": "./dist/kinds/repo/testing.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "version:patch": "npm version patch && git push && git push --tags",
    "version:minor": "npm version minor && git push && git push --tags",
    "version:major": "npm version major && git push && git push --tags",
    "publish:npm": "npm run build && npm publish"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexngai/agent-workspace.git"
  },
  "license": "MIT",
  "author": "Alex Ngai",
  "peerDependencies": {
    "@anthropic-ai/sandbox-runtime": ">=0.0.40"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sandbox-runtime": {
      "optional": true
    }
  },
  "dependencies": {
    "git-url-parse": "^16.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.42",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
